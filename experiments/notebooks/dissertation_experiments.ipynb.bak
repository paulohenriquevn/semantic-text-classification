    "# ---------------------------------------------------------------------------\n",
    "# §4.1 Load H1 results\n",
    "# ---------------------------------------------------------------------------\n",
    "h1_results = load_results(\"H1\")\n",
    "h1_df = results_to_df(h1_results)\n",
