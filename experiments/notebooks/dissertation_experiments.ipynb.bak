      "Intent                      Original  Synthetic      Delta\n",
      "-------------------------------------------------------\n",
      "cancelamento                   0.592      0.616     +0.024\n",
      "compra                         0.579      0.606     +0.027\n",
      "duvida_produto                 0.578      0.587     +0.009\n",
      "duvida_servico                 0.578      0.587     +0.009\n",
      "elogio                         0.595      0.620     +0.025\n",
